# ─────────────────────────────────────────────────────────────────
# Dependencies
# ─────────────────────────────────────────────────────────────────
node_modules/
.venv/
venv/
env/

# ─────────────────────────────────────────────────────────────────
# Build output
# ─────────────────────────────────────────────────────────────────
dist/
build/
*.tsbuildinfo

# ─────────────────────────────────────────────────────────────────
# Python
# ─────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.benchmarks/
.deepeval/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# ─────────────────────────────────────────────────────────────────
# Environment / secrets — never commit real values
# ─────────────────────────────────────────────────────────────────
.env
.env.*
!.env.example
!.env.development
!.env.production
*.key
*.pem
secrets.json
config.json
.suite.pids
.server.pids
.server.pid

# ─────────────────────────────────────────────────────────────────
# Local databases (generated at runtime)
# ─────────────────────────────────────────────────────────────────
*.db
*.db-wal
*.db-shm
*.sqlite
*.sqlite3

# ─────────────────────────────────────────────────────────────────
# Bundled dataset — committed so a fresh clone runs with real, populated
# data out of the box: the explorer loads kgs/*.json into JanusGraph on the
# first `setup`, kbs/ backs the source-document reference links, and
# compliance-files/ + pipeline-output/ let the pipeline be re-run/inspected.
# Only genuinely runtime artifacts (logs, the UI run database) stay ignored.
# ─────────────────────────────────────────────────────────────────
apps/pipeline/pipeline-data/
apps/pipeline/pipeline-logs/

# ─────────────────────────────────────────────────────────────────
# Media / generated artifacts
# ─────────────────────────────────────────────────────────────────
tools/video/output/
tools/video/screenshots/
tools/video/raw_video/
*.mp4
*.webm
*.mp3

# ─────────────────────────────────────────────────────────────────
# Test outputs
# ─────────────────────────────────────────────────────────────────
**/test-results/
**/playwright-report/
**/.playwright-mcp/

# Allure + coverage artifacts
**/allure-results/
**/allure-report/
**/coverage/
**/coverage-html/
**/coverage.xml
.coverage

# ─────────────────────────────────────────────────────────────────
# OS / editor
# ─────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp

# Runtime symlink created by start.sh -> apps/pipeline/pipeline-output (machine-specific)
apps/explorer/pipeline-output
