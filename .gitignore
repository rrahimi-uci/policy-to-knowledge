# ─────────────────────────────────────────────────────────────────
# Dependencies
# ─────────────────────────────────────────────────────────────────
node_modules/
.venv/
venv/
env/

# ─────────────────────────────────────────────────────────────────
# Build output
# ─────────────────────────────────────────────────────────────────
dist/
build/
*.tsbuildinfo

# ─────────────────────────────────────────────────────────────────
# Python
# ─────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.benchmarks/
.deepeval/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# ─────────────────────────────────────────────────────────────────
# Environment / secrets — never commit real values
# ─────────────────────────────────────────────────────────────────
.env
.env.*
!.env.example
!.env.development
!.env.production
*.key
*.pem
secrets.json
config.json
.suite.pids
.server.pids
.server.pid

# ─────────────────────────────────────────────────────────────────
# Local databases (generated at runtime)
# ─────────────────────────────────────────────────────────────────
*.db
*.db-wal
*.db-shm
*.sqlite
*.sqlite3

# ─────────────────────────────────────────────────────────────────
# Proprietary / user-supplied data — NOT distributed.
# The directory skeletons (README + .gitkeep) are kept so the apps and
# Docker builds work; their data contents are ignored. Users supply their
# own data — see each app's README.
# ─────────────────────────────────────────────────────────────────
apps/explorer/kbs/*
!apps/explorer/kbs/.gitkeep
!apps/explorer/kbs/README.md
apps/explorer/kgs/*
!apps/explorer/kgs/.gitkeep
!apps/explorer/kgs/README.md
apps/pipeline/compliance-files/*
!apps/pipeline/compliance-files/.gitkeep
!apps/pipeline/compliance-files/README.md
apps/pipeline/pipeline-output/
apps/pipeline/pipeline-data/
apps/pipeline/pipeline-logs/

# ─────────────────────────────────────────────────────────────────
# Media / generated artifacts
# ─────────────────────────────────────────────────────────────────
tools/video/output/
tools/video/screenshots/
tools/video/raw_video/
*.mp4
*.webm
*.mp3

# ─────────────────────────────────────────────────────────────────
# Test outputs
# ─────────────────────────────────────────────────────────────────
**/test-results/
**/playwright-report/
**/.playwright-mcp/

# Allure + coverage artifacts
**/allure-results/
**/allure-report/
**/coverage/
**/coverage-html/
**/coverage.xml
.coverage

# ─────────────────────────────────────────────────────────────────
# OS / editor
# ─────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp

# Runtime symlink created by start.sh -> apps/pipeline/pipeline-output (machine-specific)
apps/explorer/pipeline-output
