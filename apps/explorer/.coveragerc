[run]
source =
    conf
    src
omit =
    */tests/*
    # Live-service modules (require JanusGraph / OpenSearch / sentence-transformers)
    # exercised by the e2e suites, not the offline unit tests.
    src/server.py
    src/semantic_search.py
    src/graph_connection.py
    src/connection_pool.py
    src/schema.py
    src/main.py
    src/docs_sync.py
    src/gremlin_queries.py

[report]
show_missing = True
skip_covered = False
exclude_lines =
    pragma: no cover
    if __name__ == .__main__.:
    raise NotImplementedError
