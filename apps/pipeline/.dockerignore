# Output directories — bundled into image so deployed UI has real data
# (Azure deploy does not mount these as volumes.)
# pipeline-output/** and compliance-files/** are intentionally NOT ignored.
# Only exclude transient subfolders if any.

# Logs / runs that should never ship
pipeline-output/openai/_runs/**
pipeline-logs/**
pipeline-data/**

# Configuration (will be provided at runtime)
config.json
.env

