# ╔═══════════════════════════════════════════════════════════════════╗
# ║  Explorer — Environment Configuration                        ║
# ║  Copy to .env and customise.  All values shown are the defaults.  ║
# ╚═══════════════════════════════════════════════════════════════════╝

# ── Infrastructure hosts / ports ──────────────────────────────────

JANUSGRAPH_HOST=localhost
JANUSGRAPH_PORT=8182
CASSANDRA_HOST=localhost
CASSANDRA_PORT=9042
OPENSEARCH_HOST=localhost
OPENSEARCH_PORT=9200

# ── Redis ─────────────────────────────────────────────────────────

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
CACHE_TTL=3600                     # Global cache TTL in seconds (1 hour)
REDIS_CONNECT_TIMEOUT=5            # Seconds
REDIS_SOCKET_TIMEOUT=5             # Seconds
REDIS_HEALTH_CHECK_INTERVAL=30     # Seconds

# ── Embedding model ───────────────────────────────────────────────

EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIM=384                  # Must match the chosen model's output dim

# ── Multi-graph ───────────────────────────────────────────────────

# DEFAULT_GRAPH=compliance_g       # Override the default traversal source

# ── Connection pool ───────────────────────────────────────────────

POOL_MIN_SIZE=2
POOL_MAX_SIZE=10
GREMLIN_MAX_INFLIGHT=64            # Max in-flight requests per Gremlin client

# ── API Keys ──────────────────────────────────────────────────────

# OpenAI API Key (required for GPT models)
OPENAI_API_KEY=your-openai-api-key-here

# Anthropic API Key (for Claude models via LiteLLM)
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Google Gemini API Key (for Gemini models via LiteLLM)
GEMINI_API_KEY=your-gemini-api-key-here

# ── OpenAI / LLM ─────────────────────────────────────────────────

OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_REASONING_EFFORT=low        # low | medium | high  (only used for reasoning models: o1, o3, gpt-5.x)
MAX_TOOL_ROUNDS=5                  # Max iterative tool-calling rounds

# ── Flask server ──────────────────────────────────────────────────

SERVER_HOST=0.0.0.0
SERVER_PORT=5000
FLASK_DEBUG=false

# ── Search defaults ───────────────────────────────────────────────

SEMANTIC_SEARCH_DEFAULT_TOP_K=5
SEMANTIC_SEARCH_CACHE_TTL=1800     # Seconds (30 minutes)
TEXT_SEARCH_MAX_RESULTS=10
FUZZY_MATCH_MAX_CANDIDATES=5
SIBLING_RULES_MAX_RESULTS=10
STATS_HUB_RULES_LIMIT=5

# ── OpenSearch k-NN index ─────────────────────────────────────────

KNN_INDEX_NAME=vertex_embeddings
KNN_EF_SEARCH=100
KNN_NUMBER_OF_SHARDS=1
KNN_NUMBER_OF_REPLICAS=0
KNN_EF_CONSTRUCTION=128
KNN_HNSW_M=24
KNN_SPACE_TYPE=cosinesimil
KNN_ENGINE=nmslib

# ── OpenSearch client ─────────────────────────────────────────────

OPENSEARCH_USE_SSL=false
OPENSEARCH_VERIFY_CERTS=false
OPENSEARCH_HTTP_COMPRESS=true
OPENSEARCH_TIMEOUT=30
OPENSEARCH_MAX_RETRIES=3
OPENSEARCH_RETRY_ON_TIMEOUT=true

# ── Schema creation ───────────────────────────────────────────────

SCHEMA_RETRIES=5
SCHEMA_RETRY_DELAY=10.0

# ── Data loader ───────────────────────────────────────────────────

DATA_LOAD_BATCH_LOG_INTERVAL=50

# ── Gremlin query defaults ────────────────────────────────────────

QUERY_DEFAULT_LIMIT=10
HIGH_CONFIDENCE_THRESHOLD=90.0
QUERY_HIGH_CONFIDENCE_MAX=15

# ── Docker / Cassandra (consumed by docker-compose.yml) ──────────

CASSANDRA_CLUSTER_NAME=jg-cluster
CASSANDRA_MAX_HEAP=512M
CASSANDRA_HEAP_NEWSIZE=128M
OPENSEARCH_JAVA_OPTS=-Xms256m -Xmx256m
OPENSEARCH_ADMIN_PASSWORD=Admin_12345!  # ⚠ CHANGE IN PRODUCTION
REDIS_MAX_MEMORY=256mb
REDIS_EVICTION_POLICY=allkeys-lru

# ── Logging ───────────────────────────────────────────────────────

LOG_LEVEL=INFO
